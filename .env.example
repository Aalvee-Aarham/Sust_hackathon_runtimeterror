# ── Gemini API Keys (comma-separated, round-robin rotation)
GEMINI_API_KEYS=key1,key2,key3

# ── Groq API Keys (comma-separated, round-robin rotation)
GROQ_API_KEYS=key1,key2,key3

# ── OpenRouter API Keys (comma-separated, round-robin rotation)
OPENROUTER_API_KEYS=key1,key2,key3

# ── Supabase (optional — async logging)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Server
PORT=3000
NODE_ENV=production
RATE_LIMIT_MAX=120

# ── LLM Provider priority (comma-separated): gemini, groq, openrouter
LLM_PRIORITY=gemini,groq,openrouter

# ── LLM timeout and retry
LLM_TIMEOUT_MS=25000
LLM_RETRY_DELAY_MS=500
LLM_MAX_RETRIES=2

# ── Model overrides (optional)
GEMINI_MODEL=gemini-2.0-flash
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_MODEL=google/gemini-2.0-flash-001
