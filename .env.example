# ── Gemini API Keys (comma-separated, will be rotated round-robin)
GEMINI_API_KEYS=key1,key2,key3

# ── Groq API Keys (comma-separated, will be rotated round-robin)
GROQ_API_KEYS=key1,key2,key3

# ── OpenRouter API Keys (comma-separated, will be rotated round-robin)
OPENROUTER_API_KEYS=key1,key2,key3

# ── Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SUPABASE_PUBLISHABLE_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Server
PORT=3000
NODE_ENV=production

# ── LLM Provider priority order (comma-separated): gemini, groq, openrouter
LLM_PRIORITY=gemini,groq,openrouter

# ── Timeout per LLM call in ms
LLM_TIMEOUT_MS=25000
